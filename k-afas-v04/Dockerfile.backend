# K-AFAS Backend (FastAPI)
FROM python:3.11-slim

WORKDIR /app

# 의존성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 소스 복사
COPY kafas/ ./kafas/
COPY app/ ./app/

# 로그 디렉토리
RUN mkdir -p /app/logs

EXPOSE 8000

CMD ["uvicorn", "app.gateway:app", "--host", "0.0.0.0", "--port", "8000"]
